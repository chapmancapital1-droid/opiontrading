# ============================================================================
# OptionScope environment (server-side only — never prefix data secrets with
# NEXT_PUBLIC_). Copy to .env.local and fill in.
# ============================================================================

# --- Market data provider selection -----------------------------------------
# One of: demo | polygon | openbb
MARKET_DATA_PROVIDER=openbb

# Polygon (only if MARKET_DATA_PROVIDER=polygon)
# MARKET_DATA_API_KEY=your_polygon_key
# MARKET_DATA_BASE_URL=https://api.polygon.io

# --- OpenBB (live market data + news via one REST API) ----------------------
# Run the OpenBB REST server (see docs/OPENBB_SETUP.md):
#   pip install openbb
#   uvicorn openbb_core.api.rest_api:app --host 0.0.0.0 --port 8000
OPENBB_BASE_URL=http://localhost:8000
# Which downstream provider OpenBB should use for quotes/chains (cboe is free):
OPENBB_API_PROVIDER=cboe
# Honest freshness label in minutes (OpenBB/CBOE data is typically ~15m delayed
# unless your provider entitlement is real-time). The UI shows this.
OPENBB_DELAY_MINUTES=15

# Provider API keys live in OpenBB's OWN config (~/.openbb_platform/user_settings.json),
# NOT here — that's the point of routing through OpenBB.

# --- News provider selection ------------------------------------------------
# One of: none | openbb
NEWS_PROVIDER=openbb
# Which downstream provider OpenBB uses for news (benzinga, tiingo, fmp, intrinio, …):
NEWS_API_PROVIDER=benzinga
