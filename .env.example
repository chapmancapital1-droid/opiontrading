# ---- Server-only secrets. NEVER prefix market-data keys with NEXT_PUBLIC_ ----
MARKET_DATA_PROVIDER=demo          # demo | polygon | openbb
MARKET_DATA_API_KEY=               # licensed provider key (server only; polygon)
MARKET_DATA_BASE_URL=

# ---- OpenBB (live market data + news via one REST API) --------------------
# Run:  pip install openbb && uvicorn openbb_core.api.rest_api:app --port 8000
# Set MARKET_DATA_PROVIDER=openbb to use it. See docs/OPENBB_SETUP.md.
OPENBB_BASE_URL=http://localhost:8000
OPENBB_API_PROVIDER=cboe           # downstream provider OpenBB uses (cboe is free)
OPENBB_DELAY_MINUTES=15            # honest freshness label shown in the UI
# Provider keys live in OpenBB's own config, NOT here.

# ---- News -----------------------------------------------------------------
NEWS_PROVIDER=none                 # none | openbb
NEWS_API_PROVIDER=benzinga         # downstream provider for news (benzinga, tiingo, fmp, …)

# ---- Supabase (journal / auth) --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # server only

# ---- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=OptionScope

# ---- NCI TA / TradingView webhook (optional) -------------------------------
# Header x-nci-ta-secret must match when set. POST /api/nci-ta/webhook
NCI_TA_WEBHOOK_SECRET=
